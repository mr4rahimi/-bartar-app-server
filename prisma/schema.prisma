// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  admin
  technician
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  NOT_REPAIRABLE
  CANCELLED
  COMPLETED
}

enum OrderStage {
  REGISTERED
  PRICE_SET
  TECHNICIAN_ASSIGNED
  IN_REPAIR
  READY_FOR_PICKUP
  COMPLETED
}

enum PickupMethod {
  PICKUP // پیک
  IN_PERSON // مراجعه حضوری
  ON_SITE // تعمیر در محل
}

enum DevicePlatform {
  android
  ios
  web
}


enum NotificationChannel {
  PUSH
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum OtpPurpose {
  REGISTER
  LOGIN
}

model OtpCode {
  id          Int        @id @default(autoincrement())
  phone       String
  purpose     OtpPurpose
  codeHash    String     @db.VarChar(255)
  expiresAt   DateTime
  consumedAt  DateTime?
  attempts    Int        @default(0)
  createdAt   DateTime   @default(now())

  @@index([phone, purpose, createdAt])
  @@index([expiresAt])
}

model Notification {
  id        Int                @id @default(autoincrement())
  userId    Int
  channel   NotificationChannel
  status    NotificationStatus @default(PENDING)
  title     String?
  body      String
  dataJson  String?            @db.Text
  provider  String?            // e.g. "stub", "fcm"
  error     String?            @db.Text
  createdAt DateTime           @default(now())
  sentAt    DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId, channel, status])
}


model User {
  id                Int                 @id @default(autoincrement())
  name              String?
  phone             String              @unique
  email             String?             @unique
  password          String
  role              Role                @default(user)
  orders            Order[]
  tickets           Ticket[]
  reports           OrderReport[]
  walletBalance     Int                 @default(0)
  transactions      WalletTransaction[]
  assignedOrders    Order[]             @relation("OrderTechnician")
  deviceTokens       DeviceToken[]
  notifications Notification[]
  createdAt         DateTime            @default(now())
  TechnicianProfile TechnicianProfile?
}

model DeviceToken {
  id         Int            @id @default(autoincrement())
  userId     Int
  token      String         @unique
  platform   DevicePlatform @default(android)
  isActive   Boolean        @default(true)
  lastSeenAt DateTime       @default(now())
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}


model TechnicianProfile {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  bio        String?
  experience Int?
  rating     Float?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model WalletTransaction {
  id        Int      @id @default(autoincrement())
  userId    Int
  amount    Int // مثبت=افزایش، منفی=کاهش (واحد: تومان)
  type      String // e.g. "admin_adjust", "order_refund", "topup"
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Order {
  id                    Int          @id @default(autoincrement())
  orderNumber           String       @unique
  userId                Int
  serviceId             Int?
  brandId               Int?
  modelId               Int?
  deviceType            String
  brand                 String?
  model                 String?
  issue                 String
  imageUrl              String?
  status                OrderStatus  @default(PENDING)
  orderStage            OrderStage   @default(REGISTERED)
  notes                 String?
  pickupMethod          PickupMethod
  basePrice             Float?
  finalPrice            Float?
  finalPriceConfirmed   Boolean      @default(false)
  finalPriceConfirmedAt DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  user     User         @relation(fields: [userId], references: [id])
  service  Service?     @relation(fields: [serviceId], references: [id])
  brandRel Brand?       @relation(fields: [brandId], references: [id])
  modelRel DeviceModel? @relation(fields: [modelId], references: [id])

  technicianId Int?
  technician   User? @relation("OrderTechnician", fields: [technicianId], references: [id])

  problemId Int?
  problem   Problem? @relation(fields: [problemId], references: [id])

  reports OrderReport[]
}

model OrderReport {
  id        Int      @id @default(autoincrement())
  orderId   Int
  actorId   Int?
  action    String
  details   String?
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])
  actor User? @relation(fields: [actorId], references: [id])
}

model Service {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  iconUrl     String?
  description String?
  createdAt   DateTime @default(now())
  active      Boolean  @default(true)

  brands  BrandService[]
  models  DeviceModel[]
  Order   Order[]
  Problem Problem[]

  parts      Part[] // ⬅ قطعات این سرویس
  partPrices PartPrice[] // ⬅ قیمت‌های قطعات برای این سرویس
  partLabors PartLabor[]
}

model Brand {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  iconUrl     String?
  description String?
  createdAt   DateTime @default(now())
  active      Boolean  @default(true)

  services BrandService[]
  models   DeviceModel[]
  Order    Order[]

  partPrices PartPrice[] // ⬅ قیمت‌های قطعات برای این برند
  partLabors PartLabor[]
}

model BrandService {
  id        Int @id @default(autoincrement())
  brandId   Int
  serviceId Int

  brand   Brand   @relation(fields: [brandId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])

  @@unique([brandId, serviceId])
}

model DeviceModel {
  id        Int      @id @default(autoincrement())
  name      String
  code      String? // مثلاً A16 یا مدل داخلی
  brandId   Int
  serviceId Int? // اختیاری — اگر لازم باشه محدود به سرویس خاص
  createdAt DateTime @default(now())
  active    Boolean  @default(true)

  brand   Brand    @relation(fields: [brandId], references: [id])
  service Service? @relation(fields: [serviceId], references: [id])
  Order   Order[]

  partPrices PartPrice[] // ⬅ قیمت قطعات برای این مدل
  partLabors PartLabor[]

  @@unique([brandId, name]) // تضمین می‌کنه یک مدل برای یک برند تکرار نشه
}

model Problem {
  id        Int      @id @default(autoincrement())
  name      String
  code      String? // optional internal code
  serviceId Int
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  service Service @relation(fields: [serviceId], references: [id])

  problemParts ProblemPart[]
  orders       Order[]

  @@unique([serviceId, name])
  @@index([serviceId])
}

model Banner {
  id        Int      @id @default(autoincrement())
  title     String?
  imageUrl  String
  linkUrl   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Ticket {
  id        Int      @id @default(autoincrement())
  userId    Int
  subject   String
  message   String
  status    String   @default("open") // open, closed, pending
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Part {
  id        Int      @id @default(autoincrement())
  name      String
  code      String?
  serviceId Int
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  service         Service       @relation(fields: [serviceId], references: [id])
  prices          PartPrice[]
  problemMappings ProblemPart[]
  labors          PartLabor[]

  @@unique([serviceId, name])
}

model PartPrice {
  id        Int      @id @default(autoincrement())
  serviceId Int
  brandId   Int?
  modelId   Int?
  partId    Int
  price     Int

  highCopyPrice Int?
  copyPrice     Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  service Service      @relation(fields: [serviceId], references: [id])
  brand   Brand?       @relation(fields: [brandId], references: [id])
  model   DeviceModel? @relation(fields: [modelId], references: [id])
  part    Part         @relation(fields: [partId], references: [id])

  @@unique([serviceId, brandId, modelId, partId])
  @@index([serviceId, brandId, modelId, partId])
}

model ProblemPart {
  id        Int      @id @default(autoincrement())
  problemId Int
  partId    Int
  createdAt DateTime @default(now())

  problem Problem @relation(fields: [problemId], references: [id])
  part    Part    @relation(fields: [partId], references: [id])

  @@unique([problemId])
}

model PartLabor {
  id        Int      @id @default(autoincrement())
  serviceId Int
  partId    Int
  brandId   Int?
  modelId   Int?
  laborFee  Int // تومان
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  service Service      @relation(fields: [serviceId], references: [id])
  brand   Brand?       @relation(fields: [brandId], references: [id])
  model   DeviceModel? @relation(fields: [modelId], references: [id])
  part    Part         @relation(fields: [partId], references: [id])

  @@unique([serviceId, partId, brandId, modelId])
  @@index([serviceId, partId, brandId, modelId])
}

model PricingConfig {
  id                Int      @id @default(1)
  partMarkupPercent Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
