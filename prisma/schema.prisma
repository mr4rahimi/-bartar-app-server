generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model OtpCode {
  id         Int        @id @default(autoincrement())
  phone      String
  purpose    OtpPurpose
  codeHash   String     @db.VarChar(255)
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int        @default(0)
  createdAt  DateTime   @default(now())

  @@index([phone, purpose, createdAt])
  @@index([expiresAt])
}

model Notification {
  id        Int                 @id @default(autoincrement())
  userId    Int
  channel   NotificationChannel
  status    NotificationStatus  @default(PENDING)
  title     String?
  body      String
  dataJson  String?             @db.Text
  provider  String?
  error     String?             @db.Text
  createdAt DateTime            @default(now())
  sentAt    DateTime?
  user      User                @relation(fields: [userId], references: [id], onDelete: NoAction)

  @@index([userId, channel, status])
}

model User {
  id                Int                 @id @default(autoincrement())
  name              String?
  phone             String              @unique
  email             String?             @unique
  password          String
  role              Role                @default(user)
  createdAt         DateTime            @default(now())
  walletBalance     Int                 @default(0)
  deviceTokens      DeviceToken[]
  notifications     Notification[]
  assignedOrders    Order[]             @relation("OrderTechnician")
  orders            Order[]
  reports           OrderReport[]
  TechnicianProfile TechnicianProfile?
  tickets           Ticket[]
  transactions      WalletTransaction[]
  callLogs          CallLog[]           @relation("UserCallLogs")
}

model DeviceToken {
  id         Int            @id @default(autoincrement())
  userId     Int
  token      String         @unique
  platform   DevicePlatform @default(android)
  isActive   Boolean        @default(true)
  lastSeenAt DateTime       @default(now())
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  user       User           @relation(fields: [userId], references: [id], onDelete: NoAction)

  @@index([userId])
}

model TechnicianProfile {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  bio        String?
  experience Int?
  rating     Float?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: NoAction)
}

model WalletTransaction {
  id        Int      @id @default(autoincrement())
  userId    Int
  amount    Int
  type      String
  note      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: NoAction)

  @@index([userId])
}

model Order {
  id                    Int           @id @default(autoincrement())
  orderNumber           String        @unique
  userId                Int
  deviceType            String
  brand                 String?
  model                 String?
  issue                 String
  imageUrl              String?
  status                OrderStatus   @default(PENDING)
  orderStage            OrderStage    @default(REGISTERED)
  notes                 String?
  pickupMethod          PickupMethod
  basePrice             Float?
  finalPrice            Float?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  brandId               Int?
  modelId               Int?
  serviceId             Int?
  technicianId          Int?
  finalPriceConfirmed   Boolean       @default(false)
  finalPriceConfirmedAt DateTime?
  problemId             Int?
  brandRel              Brand?        @relation(fields: [brandId], references: [id])
  modelRel              DeviceModel?  @relation(fields: [modelId], references: [id])
  problem               Problem?      @relation(fields: [problemId], references: [id])
  service               Service?      @relation(fields: [serviceId], references: [id])
  technician            User?         @relation("OrderTechnician", fields: [technicianId], references: [id])
  user                  User          @relation(fields: [userId], references: [id], onDelete: NoAction)
  reports               OrderReport[]

  @@index([brandId], map: "Order_brandId_fkey")
  @@index([modelId], map: "Order_modelId_fkey")
  @@index([problemId], map: "Order_problemId_fkey")
  @@index([serviceId], map: "Order_serviceId_fkey")
  @@index([technicianId], map: "Order_technicianId_fkey")
  @@index([userId], map: "Order_userId_fkey")
}

model OrderReport {
  id        Int      @id @default(autoincrement())
  orderId   Int
  actorId   Int?
  action    String
  details   String?
  createdAt DateTime @default(now())
  actor     User?    @relation(fields: [actorId], references: [id])
  order     Order    @relation(fields: [orderId], references: [id], onDelete: NoAction)

  @@index([actorId], map: "OrderReport_actorId_fkey")
  @@index([orderId], map: "OrderReport_orderId_fkey")
}

model Service {
  id          Int            @id @default(autoincrement())
  name        String
  iconUrl     String?
  createdAt   DateTime       @default(now())
  active      Boolean        @default(true)
  description String?
  slug        String         @unique
  brands      BrandService[]
  models      DeviceModel[]
  Order       Order[]
  parts       Part[]
  partLabors  PartLabor[]
  partPrices  PartPrice[]
  Problem     Problem[]
}

model Brand {
  id          Int            @id @default(autoincrement())
  name        String
  iconUrl     String?
  createdAt   DateTime       @default(now())
  active      Boolean        @default(true)
  description String?
  slug        String         @unique
  services    BrandService[]
  models      DeviceModel[]
  Order       Order[]
  partLabors  PartLabor[]
  partPrices  PartPrice[]
}

model BrandService {
  id        Int     @id @default(autoincrement())
  brandId   Int
  serviceId Int
  brand     Brand   @relation(fields: [brandId], references: [id], onDelete: NoAction)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: NoAction)

  @@unique([brandId, serviceId])
  @@index([serviceId], map: "BrandService_serviceId_fkey")
}

model DeviceModel {
  id         Int         @id @default(autoincrement())
  name       String
  code       String?
  brandId    Int
  serviceId  Int?
  createdAt  DateTime    @default(now())
  active     Boolean     @default(true)
  brand      Brand       @relation(fields: [brandId], references: [id], onDelete: NoAction)
  service    Service?    @relation(fields: [serviceId], references: [id])
  Order      Order[]
  partLabors PartLabor[]
  partPrices PartPrice[]

  @@unique([brandId, name])
  @@index([serviceId], map: "DeviceModel_serviceId_fkey")
}

model Problem {
  id           Int          @id @default(autoincrement())
  name         String
  code         String?
  serviceId    Int
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  orders       Order[]
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: NoAction)
  problemParts ProblemPart?

  @@unique([serviceId, name])
  @@index([serviceId])
}

model Banner {
  id        Int      @id @default(autoincrement())
  title     String?
  imageUrl  String
  linkUrl   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Ticket {
  id        Int      @id @default(autoincrement())
  userId    Int
  subject   String
  message   String
  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: NoAction)

  @@index([userId], map: "Ticket_userId_fkey")
}

model Part {
  id              Int           @id @default(autoincrement())
  name            String
  code            String?
  serviceId       Int
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  service         Service       @relation(fields: [serviceId], references: [id], onDelete: NoAction)
  labors          PartLabor[]
  prices          PartPrice[]
  problemMappings ProblemPart[]

  @@unique([serviceId, name])
}

model PartPrice {
  id            Int          @id @default(autoincrement())
  serviceId     Int
  brandId       Int?
  modelId       Int?
  partId        Int
  price         Int
  highCopyPrice Int?
  copyPrice     Int?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  brand         Brand?       @relation(fields: [brandId], references: [id])
  model         DeviceModel? @relation(fields: [modelId], references: [id])
  part          Part         @relation(fields: [partId], references: [id], onDelete: NoAction)
  service       Service      @relation(fields: [serviceId], references: [id], onDelete: NoAction)

  @@unique([serviceId, brandId, modelId, partId])
  @@index([serviceId, brandId, modelId, partId])
  @@index([brandId], map: "PartPrice_brandId_fkey")
  @@index([modelId], map: "PartPrice_modelId_fkey")
  @@index([partId], map: "PartPrice_partId_fkey")
}

model ProblemPart {
  id        Int      @id @default(autoincrement())
  problemId Int      @unique
  partId    Int
  createdAt DateTime @default(now())
  part      Part     @relation(fields: [partId], references: [id], onDelete: NoAction)
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: NoAction)

  @@index([partId], map: "ProblemPart_partId_fkey")
}

model PartLabor {
  id        Int          @id @default(autoincrement())
  serviceId Int
  partId    Int
  brandId   Int?
  modelId   Int?
  laborFee  Int
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  brand     Brand?       @relation(fields: [brandId], references: [id])
  model     DeviceModel? @relation(fields: [modelId], references: [id])
  part      Part         @relation(fields: [partId], references: [id], onDelete: NoAction)
  service   Service      @relation(fields: [serviceId], references: [id], onDelete: NoAction)

  @@unique([serviceId, partId, brandId, modelId])
  @@index([serviceId, partId, brandId, modelId])
  @@index([brandId], map: "PartLabor_brandId_fkey")
  @@index([modelId], map: "PartLabor_modelId_fkey")
  @@index([partId], map: "PartLabor_partId_fkey")
}

model PricingConfig {
  id                Int      @id @default(1)
  partMarkupPercent Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model CallLog {
  id          Int            @id @default(autoincrement())

  date        DateTime       @db.Date

  operatorId  Int
  operator   User            @relation("UserCallLogs", fields: [operatorId], references: [id])

  seq         Int

  callTime    DateTime       @default(now())

  subjectText String         @db.Text
  serviceId   Int?
  brandId     Int?
  modelId     Int?
  problemId   Int?
  partId      Int?

  callerPhone String         @db.VarChar(32)

  resultText  String?        @db.Text
  finalStatus CallFinalStatus @default(PENDING)
  finalizedAt DateTime?

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([date, operatorId])
  @@index([date])
  @@index([operatorId])
  @@unique([date, operatorId, seq])
}

enum Role {
  user
  admin
  technician
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  NOT_REPAIRABLE
  CANCELLED
  COMPLETED
}

enum OrderStage {
  REGISTERED
  PRICE_SET
  TECHNICIAN_ASSIGNED
  IN_REPAIR
  READY_FOR_PICKUP
  COMPLETED
}

enum PickupMethod {
  PICKUP
  IN_PERSON
  ON_SITE
}

enum DevicePlatform {
  android
  ios
  web
}

enum NotificationChannel {
  PUSH
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum OtpPurpose {
  REGISTER
  LOGIN
}

enum CallFinalStatus {
  PENDING
  FINAL
}
